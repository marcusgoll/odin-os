# Copy to ~/.config/odin/odin-os.env and adjust for the target machine.
# This file is a template only. Do not commit real secrets.

# Runtime state and API bind address. Keep the HTTP listener on loopback unless
# a reviewed reverse proxy or SSH tunnel controls access.
ODIN_ROOT=/home/orchestrator/.local/state/odin-os
ODIN_HTTP_ADDR=127.0.0.1:9444

# Optional dashboard/admin token for authenticated admin endpoints such as
# POST /kill-switch/on. Put the real value only in the deployed env file.
# ODIN_ADMIN_TOKEN=

# Optional project overlay and local driver paths. These may reference
# machine-local files that are not committed to Git.
# ODIN_PROJECTS_OVERLAY=/home/orchestrator/.config/odin/odin-os-projects.local.yaml
# ODIN_CODEX_DRIVER=/home/orchestrator/.config/odin/odin-codex-live-driver.sh
# ODIN_MEDIA_CONFIG=/home/orchestrator/.config/odin/media-stack.yaml

# Optional source checkout for the system project when Odin runs from a clean
# release archive that intentionally does not contain .git metadata.
# ODIN_CORE_GIT_ROOT=/home/orchestrator/odin-os

# Optional routed operator base URL used by `odin browser session login-request`
# when --handoff-base-url is omitted. Do not use localhost for SSH/homelab
# operator handoffs.
# ODIN_BROWSER_HANDOFF_BASE_URL=https://odin.marcusgoll.com/browser/session/handoff

# Optional attended browser/noVNC runner. Keep these disabled unless the display,
# browser, and websockify/noVNC commands are absolute, executable, explicitly
# allowlisted, and routed only through a private/operator viewer URL. The runner
# passes no args or custom env to role commands; use reviewed host-side wrappers
# when Xvfb, Chrome, or websockify need display, profile, port, or URL args.
# ODIN_BROWSER_HANDOFF_RUNNER=novnc
# ODIN_NOVNC_REAL_DISPLAY=true
# ODIN_NOVNC_REAL_BROWSER=true
# ODIN_NOVNC_REAL_WEBSOCKIFY=true
# ODIN_NOVNC_DISPLAY_COMMAND=/home/orchestrator/.config/odin/browser-handoff/display-vnc
# ODIN_NOVNC_BROWSER_COMMAND=/home/orchestrator/.config/odin/browser-handoff/browser
# ODIN_NOVNC_WEBSOCKIFY_COMMAND=/home/orchestrator/.config/odin/browser-handoff/websockify
# ODIN_NOVNC_ALLOWED_COMMANDS=/home/orchestrator/.config/odin/browser-handoff/display-vnc,/home/orchestrator/.config/odin/browser-handoff/browser,/home/orchestrator/.config/odin/browser-handoff/websockify
# ODIN_NOVNC_BIND_ADDR=127.0.0.1:6080
# ODIN_NOVNC_PRIVATE_BASE_URL=https://odin-handoff.tailnet.local
# ODIN_NOVNC_TIMEOUT_SECONDS=600
