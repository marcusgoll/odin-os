# Copy to ~/.config/odin/odin.env and adjust for the target machine.

ODIN_ROOT=/var/odin
ODIN_HTTP_ADDR=127.0.0.1:9443

# FLICA Tradeboard operator surface.
# Odin calls the PBS/flight-api service; AA credentials stay in that service's env.
ODIN_TRADEBOARD_API_BASE_URL=http://127.0.0.1:8083
ODIN_TRADEBOARD_API_TOKEN=
ODIN_TRADEBOARD_API_TIMEOUT_SECONDS=180
